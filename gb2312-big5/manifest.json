{
  "manifest_version": 3,
  "name": "__MSG_appName__",
  "default_locale": "en",
  "short_name": "ZH Convert",
  "version": "0.22",
  "action": {
    "default_icon": "icon.png",
    "default_title": "__MSG_appName__",
    "default_popup": "main.html"
  },
  "author": {
    "email": "dr.zhihua.lai@gmail.com"
  },
  "homepage_url": "https://github.com/DoctorLai/Simplified-and-Traditional-Chinese",
  "icons": {
    "16": "images/icon-16.png",
    "32": "images/icon-32.png",
    "48": "images/icon-48.png",
    "128": "images/icon-128.png"
  },
  "description": "__MSG_appDesc__",
  "permissions": ["storage"],
  "background": {
    "service_worker": "js/background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["js/pinyin.js", "js/dialect.js", "js/convert.js"],
      "run_at": "document_end",
      "all_frames": false
    }
  ]
}
